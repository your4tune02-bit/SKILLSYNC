        </VBox>
        <Label text="v1.0.5 PRO" styleClass="splash-version"/>
    </VBox>

    <StackPane fx:id="toastContainer" mouseTransparent="true" alignment="BOTTOM_CENTER" style="-fx-padding: 0 0 30 0;"/>
</StackPane>